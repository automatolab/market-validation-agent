    "must_include_keywords": [
      "brisket",
      "smoked brisket",
      "bbq platter",
      "catering"
    ],
    "exclude_keywords": [
      "vegetarian-only",
      "bakery",
      "coffee-only"
    ],
    "min_evidence_links": 1
  },
  "email_template": {
    "template_id": "brisket-outreach-v2-tx",
    "subject_template": "Quick brisket supply question for {{company_name}}",
    "body_template": "Hi {{contact_name_or_team}},\n\nI saw {{evidence_context}} and wanted to ask if your team is open to discussing brisket supply options for {{city_or_region}} this month.\n\nIf useful, I can share current pricing ranges, minimum order options, and delivery windows.\n\nBest,\n{{sender_name}}",
    "tone": "professional"
  },
  "default_model": "provider/model",
  "default_agent": "general"
