# Copy this file to .env before running:
#   cp .env_example .env
#
# Optional OpenCode defaults for this repo.
# Leave blank to use your OpenCode CLI defaults.
# You can still override per run with --model and --agent.
OPENCODE_MODEL=
OPENCODE_AGENT=

# Source provider API keys used by config/lead-pipeline.json
# Set only what you plan to enable.
# Foursquare Places (v3 places/search) expects raw key in Authorization header
# (no "Bearer " prefix).
# Use Places API key for places/search.
FOURSQUARE_PLACES_API_KEY=
HERE_API_KEY=
SERPAPI_API_KEY=

# pytrends / DuckDuckGo / Overpass / CommonCrawl do not require API keys.
